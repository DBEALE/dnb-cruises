{
  "name": "dnb-cruises",
  "version": "1.0.0",
  "description": "Multi-provider cruise scraper and viewer for the UK market",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "build": "node scripts/generate-build-info.js && node scripts/fetch-ship-wiki-links.js",
    "cruises:pull": "node scripts/fetch-cruises.js",
    "cruises:hydrate": "node scripts/fetch-live-cruise-data.js",
    "test": "node --test test/*.test.js && playwright test",
    "test:unit": "node --test test/*.test.js",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "cheerio": "^1.2.0",
    "express": "^4.18.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "jimp": "^1.6.1"
  }
}
